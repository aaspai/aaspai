{
  "name": "@aaspai/worker",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./src/main.ts",
  "bin": {
    "aaspai-worker": "./src/main.ts"
  },
  "scripts": {
    "dev": "tsx watch ./src/main.ts",
    "start": "tsx ./src/main.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@aaspai/contracts": "workspace:*",
    "@aaspai/db": "workspace:*",
    "@aaspai/execution": "workspace:*",
    "@aaspai/file-loader": "workspace:*",
    "@aaspai/loops": "workspace:*",
    "@aaspai/observability": "workspace:*",
    "@aaspai/sessions": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.1",
    "@types/node": "^24.0.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.16.2",
    "typescript": "^5.8.3",
    "vitest": "4.1.9"
  }
}
